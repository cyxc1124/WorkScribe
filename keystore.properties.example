# 把这份文件复制为同目录下的 keystore.properties 后填入真实值。
# keystore.properties 已加入 .gitignore，不会被提交。
#
# 没有这份文件时，release 构建会**自动退回到 debug keystore**，
# 产物可以安装到开发设备 / 模拟器，但**不能用于 Play Store 发布**。
#
# 准备一份正式签名 keystore：
#   keytool -genkeypair -v \
#     -keystore ~/.android/workscribe-release.jks \
#     -alias workscribe-release \
#     -keyalg RSA -keysize 4096 -validity 36500 \
#     -storepass <store-password> -keypass <key-password> \
#     -dname "CN=WorkScribe, O=Cyxc, C=CN"
#
# 然后把下面 4 个键填好：

storeFile=/Users/you/.android/workscribe-release.jks
storePassword=CHANGE_ME
keyAlias=workscribe-release
keyPassword=CHANGE_ME
